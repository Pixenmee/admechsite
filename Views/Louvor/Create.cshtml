@model AdMechSite.Models.Louvor

<h2>➕ Novo Louvor</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div>
        Título:<br />
        @Html.EditorFor(model => model.Titulo)
    </div>

    <div>
        Letra:<br />
        @Html.TextAreaFor(model => model.Letra, 5, 50, null)
    </div>

    <br />
    <input type="submit" value="Salvar" />
}