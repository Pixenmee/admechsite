@model IEnumerable<AdMechSite.Models.Escritura>

<h2>📜 Escrituras Sagradas</h2>

<p>
    @Html.ActionLink("➕ Nova Escritura", "Create")
</p>

<table class="table">
    <tr>
        <th>Título</th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Titulo</td>
            <td>
                @Html.ActionLink("Editar", "Edit", new { id = item.Id }) |
                @Html.ActionLink("Detalhes", "Details", new { id = item.Id }) |
                @Html.ActionLink("Excluir", "Delete", new { id = item.Id })
            </td>
        </tr>
    }
</table>