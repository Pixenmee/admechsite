@model IEnumerable<AdMechSite.Models.Seguidor>

@{
    ViewBag.Title = "Seguidores";
}

<h2>⚙️ Seguidores do Cult Mechanicus</h2>

<p>
    @Html.ActionLink("➕ Novo Seguidor", "Create")
</p>

<table class="table">
    <tr>
        <th>Nome</th>
        <th>Devoção</th>
        <th>Parte Substituída</th>
        <th>Data</th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Nome</td>
            <td>@item.GrauDeDevocao</td>
            <td>@item.ParteSubstituida</td>
            <td>@item.DataIniciacao.ToShortDateString()</td>
            <td>
                @Html.ActionLink("Editar", "Edit", new { id = item.Id }) |
                @Html.ActionLink("Detalhes", "Details", new { id = item.Id }) |
                @Html.ActionLink("Excluir", "Delete", new { id = item.Id })
            </td>
        </tr>
    }
</table>